# Network: sepolia | mainnet
NETWORK=sepolia

# Run wallet owner (Magic embedded wallet EOA or dev test key for CLI)
PRIVATE_KEY=0x...

# Particle Universal Account (dashboard.particle.network)
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=

# Magic (dashboard.magic.link) — server token validation + embedded wallet
MAGIC_SECRET_KEY=
MAGIC_PUBLISHABLE_KEY=

# Arbitrum RPC
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_MAINNET_RPC_URL=https://arb1.arbitrum.io/rpc

# Seller wallet receives USDC on Arbitrum for /synthesize
SELLER_PAY_TO=0x...

# CDP facilitator (Arbitrum settlement) — first 1,000 settlements/month free
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Server
PORT=4020
SELLER_BASE_URL=http://localhost:4020

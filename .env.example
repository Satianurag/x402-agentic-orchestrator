# testnet default — switch to mainnet only for final live demo
NETWORK=sepolia

# CLI run wallet (PRIVATE_KEY not required for Magic UI runs)
PRIVATE_KEY=0x...

# Particle Universal Account (dashboard.particle.network)
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=

# Magic (dashboard.magic.link)
MAGIC_SECRET_KEY=
MAGIC_PUBLISHABLE_KEY=

# RPC (required — no public defaults)
BASE_RPC_URL=
ARBITRUM_RPC_URL=
ARBITRUM_MAINNET_RPC_URL=

# Seller receives USDC on Arbitrum for /synthesize
SELLER_PAY_TO=0x...
SELLER_BASE_URL=http://localhost:4020

# CDP facilitator (Base Sepolia / Base mainnet buyer payments)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Arbitrum Sepolia local facilitator (CDP does not list eip155:421614)
ARBITRUM_SEPOLIA_FACILITATOR_URL=http://localhost:4031
ARBITRUM_SEPOLIA_FACILITATOR_PORT=4031
FACILITATOR_PRIVATE_KEY=0x...

# Per-service x402 base URLs (testnet → dev-harness; mainnet → real x402 endpoints)
# TAVILY_BASE_URL=http://localhost:4030/tavily
# COINGECKO_BASE_URL=http://localhost:4030/coingecko
# FIRECRAWL_BASE_URL=http://localhost:4030/firecrawl
# BROWSERBASE_BASE_URL=http://localhost:4030/browserbase
# EXA_BASE_URL=http://localhost:4030/exa

# Mainnet fallbacks (used when unset): see SERVICE_BASE_URLS in src/config/chains.ts
# TAVILY_BASE_URL=https://x402.tavily.com
# COINGECKO_BASE_URL=https://pro-api.coingecko.com/api/v3
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1/x402
# BROWSERBASE_BASE_URL=https://x402.browserbase.com
# EXA_BASE_URL=https://api.exa.ai

# Particle Universal Account RPC proxy (optional — SDK default if unset)
# UNIVERSALX_RPC_URL=

# dev-harness upstream API keys (testnet only — not shipped in src/)
DEV_HARNESS_PORT=4030
DEV_HARNESS_PAY_TO=0x...
HARNESS_TAVILY_API_KEY=
HARNESS_FIRECRAWL_API_KEY=
HARNESS_BROWSERBASE_API_KEY=
HARNESS_BROWSERBASE_PROJECT_ID=
HARNESS_EXA_API_KEY=

# Gemini synthesis (required for /synthesize deliverable; model locked to gemini-3.1-flash-lite)
GEMINI_API_KEY=

# Server
PORT=4020

# E2E overrides (optional)
E2E_GOAL=BTC price brief with cited web context
E2E_BUDGET=0.15

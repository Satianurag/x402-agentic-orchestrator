# mainnet for live x402 services (Base); sepolia only for /synthesize seller testing
NETWORK=mainnet

# Run wallet EOA — must match Magic-provisioned wallet address
PRIVATE_KEY=0x...

# Particle Universal Account (dashboard.particle.network)
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=

# Magic (dashboard.magic.link)
MAGIC_SECRET_KEY=
MAGIC_PUBLISHABLE_KEY=

# RPC
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_MAINNET_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Seller wallet receives USDC on Arbitrum for /synthesize
SELLER_PAY_TO=0x...

# CDP facilitator (required)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# LLM synthesis (required for /synthesize deliverable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Server
PORT=4020
SELLER_BASE_URL=http://localhost:4020

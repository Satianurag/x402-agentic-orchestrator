{
  "name": "x402-agentic-orchestrator",
  "version": "1.0.0",
  "description": "Pay-per-use AI agent that orchestrates x402 micro-services with on-chain budget",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/server/seller.ts",
    "cli": "tsx src/cli.ts",
    "dev": "tsx watch src/server/seller.ts"
  },
  "dependencies": {
    "@coinbase/x402": "2.1.0",
    "@magic-sdk/admin": "2.8.2",
    "@particle-network/universal-account-sdk": "2.0.3",
    "@x402/core": "2.18.0",
    "@x402/evm": "2.18.0",
    "@x402/express": "2.18.0",
    "@x402/fetch": "2.18.0",
    "dotenv": "17.4.2",
    "ethers": "6.17.0",
    "express": "4.22.2",
    "viem": "2.55.2"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/node": "22.20.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}

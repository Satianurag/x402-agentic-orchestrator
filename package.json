    "@x402/evm": "^2.18.0",
    "@x402/express": "^2.18.0",
    "@x402/fetch": "^2.18.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "viem": "^2.23.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
